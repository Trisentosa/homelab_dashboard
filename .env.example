# Password to log into the dashboard
DASHBOARD_PASSWORD=changeme

# Secret used to sign session cookies (must be at least 32 characters)
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# Path to the services config file (default: /config/services.yaml)
CONFIG_PATH=/config/services.yaml

# Set to "true" only when serving over HTTPS. Leave unset (or false) for plain HTTP.
COOKIE_SECURE=false
